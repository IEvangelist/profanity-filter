---
import BaseLayout from '../layouts/BaseLayout.astro';
import StrategyCard from '../components/StrategyCard.astro';
import Callout from '../components/Callout.astro';
import SectionEyebrow from '../components/SectionEyebrow.astro';
import { Icon } from 'astro-icon/components';

const inputs = [
  {
    name: 'token',
    required: true,
    type: 'string',
    typeIcon: 'ph:text-aa-duotone',
    description: 'GitHub token used to update issues and pull requests. Use the built-in `${{ secrets.GITHUB_TOKEN }}` for the simplest setup.',
  },
  {
    name: 'replacement-strategy',
    required: false,
    type: 'enum',
    typeIcon: 'ph:list-duotone',
    default: 'asterisk',
    description: 'How profane content should be replaced. See the strategy reference below for all 14 options. Case-insensitive; hyphens are also accepted (e.g. `anger-emoji`).',
  },
  {
    name: 'include-updated-note',
    required: false,
    type: 'boolean',
    typeIcon: 'ph:toggle-right-duotone',
    default: 'true',
    description: 'When `true`, appends a note to the body explaining that the content was updated by the profanity filter.',
  },
  {
    name: 'include-confused-reaction',
    required: false,
    type: 'boolean',
    typeIcon: 'ph:toggle-right-duotone',
    default: 'false',
    description: 'When `true`, the action reacts to the issue or pull request with the 😕 confused reaction.',
  },
  {
    name: 'manual-profane-words',
    required: false,
    type: 'string',
    typeIcon: 'ph:text-aa-duotone',
    description: 'A comma-separated list of additional words to include in the filter. Layered on top of the built-in dictionary.',
  },
  {
    name: 'custom-profane-words-url',
    required: false,
    type: 'url',
    typeIcon: 'ph:link-duotone',
    description: 'A URL returning a newline-separated list of words to include in the filter.',
  },
];

const strategies = [
  { name: 'asterisk', example: '****', description: 'Classic asterisks — the safe default.' },
  { name: 'emoji', example: '💩', description: 'A random expressive emoji per match.' },
  { name: 'grawlix', example: '#%$!', description: 'Comic-book style symbol soup.' },
  { name: 'bold-grawlix', example: '<strong>#%$!</strong>', description: 'Grawlix, but louder.', isHtml: true },
  { name: 'bleep', example: 'bleep', description: 'Replaces with the literal word "bleep".' },
  { name: 'redacted-rectangle', example: '████', description: 'Top-secret redaction blocks.' },
  { name: 'anger-emoji', example: '😡', description: 'A random anger-themed emoji.' },
  { name: 'middle-asterisk', example: 'f**k', description: 'Keeps first and last letters intact.' },
  { name: 'middle-swear-emoji', example: 'f🤬k', description: 'A swear emoji in the middle.' },
  { name: 'random-asterisk', example: '* — ****', description: 'Random number of asterisks.' },
  { name: 'first-letter-then-asterisk', example: 'f***', description: 'Keep the first letter only.' },
  { name: 'vowel-asterisk', example: 'sh*t', description: 'Replaces only the vowels.' },
  { name: 'strike-through', example: '<del>shit</del>', description: 'Wraps content in &lt;del&gt; tags.', isHtml: true },
  { name: 'underscores', example: '____', description: 'Replaces with underscores.' },
];

const languages = [
  { code: 'EN', name: 'English' },
  { code: 'ES', name: 'Spanish' },
  { code: 'FR', name: 'French' },
  { code: 'DE', name: 'German' },
  { code: 'IT', name: 'Italian' },
  { code: 'PT', name: 'Portuguese' },
  { code: 'RU', name: 'Russian' },
  { code: 'AR', name: 'Arabic' },
  { code: 'ZH', name: 'Chinese' },
];
---

<BaseLayout
  title="API reference — Potty Mouth"
  description="All inputs, replacement strategies, and supported languages for the Potty Mouth GitHub Action."
>
  <section class="max-w-5xl mx-auto px-6 lg:px-8 py-16 sm:py-20">
    <div class="max-w-2xl">
      <SectionEyebrow icon="ph:book-bookmark-duotone" label="Reference" />
      <h1 class="mt-3 text-4xl sm:text-5xl font-bold tracking-tight text-ink-900 dark:text-white">API reference</h1>
      <p class="mt-5 text-lg leading-relaxed text-ink-600 dark:text-ink-300">
        Every input, every strategy, every language. Only <code class="font-mono">token</code> is required &mdash;
        everything else is sensible defaults you can override when you need to.
      </p>
    </div>

    <!-- Inputs -->
    <h2 class="mt-16 flex items-center gap-2 text-2xl font-bold tracking-tight text-ink-900 dark:text-white">
      <Icon name="ph:sliders-horizontal-duotone" class="h-5 w-5 text-brand-600 dark:text-brand-400" />
      Inputs
    </h2>
    <div class="mt-6 space-y-3">
      {inputs.map(input => (
        <div class="rounded-2xl border border-ink-200/80 dark:border-white/5 bg-white/60 dark:bg-white/[0.02] p-5 transition-colors hover:border-brand-300/60 dark:hover:border-brand-500/30">
          <div class="flex flex-wrap items-baseline gap-2">
            <code class="font-mono text-base font-semibold text-ink-900 dark:text-white">{input.name}</code>
            {input.required ? (
              <span class="inline-flex items-center gap-1 rounded-full bg-brand-100 dark:bg-brand-950/60 text-brand-700 dark:text-brand-300 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wider">
                <Icon name="ph:asterisk-duotone" class="h-3 w-3" />
                Required
              </span>
            ) : (
              <span class="inline-flex items-center rounded-full bg-ink-100 dark:bg-white/5 text-ink-600 dark:text-ink-400 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wider">
                Optional
              </span>
            )}
            <span class="inline-flex items-center gap-1 rounded-full border border-ink-200 dark:border-white/10 px-2 py-0.5 text-[10px] font-medium text-ink-500 dark:text-ink-400">
              <Icon name={input.typeIcon} class="h-3 w-3" />
              {input.type}
            </span>
            {input.default && (
              <span class="text-xs text-ink-500 dark:text-ink-500">
                default: <code class="font-mono">{input.default}</code>
              </span>
            )}
          </div>
          <p class="mt-2.5 text-sm leading-relaxed text-ink-600 dark:text-ink-300" set:html={input.description.replace(/`([^`]+)`/g, '<code class="font-mono text-xs px-1.5 py-0.5 rounded bg-ink-100 dark:bg-white/10">$1</code>')}></p>
        </div>
      ))}
    </div>

    <!-- Strategies -->
    <h2 class="mt-16 flex items-center gap-2 text-2xl font-bold tracking-tight text-ink-900 dark:text-white">
      <Icon name="ph:paint-brush-duotone" class="h-5 w-5 text-brand-600 dark:text-brand-400" />
      Replacement strategies
    </h2>
    <p class="mt-3 text-ink-600 dark:text-ink-300 max-w-2xl">
      Each strategy demonstrated against a four-letter profane word. Strategy values are case-insensitive
      and accept hyphenated alternatives.
    </p>
    <div class="mt-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {strategies.map(s => (
        <StrategyCard name={s.name} example={s.example} description={s.description} isHtml={s.isHtml} />
      ))}
    </div>

    <Callout variant="tip" title="Asterisks are auto-escaped">
      <p>
        All asterisk-based strategies are escaped with a backslash <code class="font-mono">\</code>
        in body content so Markdown won't interpret them as bold. You don't need to escape anything yourself.
        Title updates intentionally aren't escaped &mdash; Markdown is supported in titles.
      </p>
    </Callout>

    <!-- Languages -->
    <h2 class="mt-16 flex items-center gap-2 text-2xl font-bold tracking-tight text-ink-900 dark:text-white">
      <Icon name="ph:globe-duotone" class="h-5 w-5 text-brand-600 dark:text-brand-400" />
      Supported languages
    </h2>
    <p class="mt-3 text-ink-600 dark:text-ink-300 max-w-2xl">
      Word lists are stored as plain newline-delimited text files. They're auditable, contributable,
      and shipped right alongside the action.
    </p>
    <div class="mt-6 flex flex-wrap gap-2">
      {languages.map(l => (
        <span class="inline-flex items-center gap-2 rounded-full border border-ink-200 dark:border-white/10 bg-white/60 dark:bg-white/[0.02] px-3.5 py-1.5 text-sm">
          <span class="font-mono text-xs font-semibold text-brand-600 dark:text-brand-400">{l.code}</span>
          <span class="text-ink-700 dark:text-ink-300">{l.name}</span>
        </span>
      ))}
    </div>
    <p class="mt-6 text-sm text-ink-500 dark:text-ink-400">
      Browse the dictionaries
      <a class="inline-flex items-center gap-1 text-brand-600 dark:text-brand-400 underline underline-offset-2" href="https://github.com/IEvangelist/profanity-filter/tree/main/src/ProfanityFilter.Services/Data" target="_blank" rel="noopener noreferrer">
        in the Data directory on GitHub
        <Icon name="ph:arrow-up-right-duotone" class="h-3.5 w-3.5" />
      </a>
    </p>

    <!-- Behavior -->
    <h2 class="mt-16 flex items-center gap-2 text-2xl font-bold tracking-tight text-ink-900 dark:text-white">
      <Icon name="ph:flow-arrow-duotone" class="h-5 w-5 text-brand-600 dark:text-brand-400" />
      What the action does
    </h2>
    <ul class="mt-4 space-y-2.5 text-ink-700 dark:text-ink-300">
      <li class="flex gap-3">
        <Icon name="ph:check-circle-duotone" class="mt-0.5 h-5 w-5 shrink-0 text-brand-600 dark:text-brand-400" />
        <span>Replaces any detected profane content using your configured strategy.</span>
      </li>
      <li class="flex gap-3">
        <Icon name="ph:check-circle-duotone" class="mt-0.5 h-5 w-5 shrink-0 text-brand-600 dark:text-brand-400" />
        <span>Optionally reacts to the issue or pull request with the 😕 confused reaction.</span>
      </li>
      <li class="flex gap-3">
        <Icon name="ph:check-circle-duotone" class="mt-0.5 h-5 w-5 shrink-0 text-brand-600 dark:text-brand-400" />
        <span>Applies the <code class="font-mono text-xs px-1.5 py-0.5 rounded bg-ink-100 dark:bg-white/10">profane content 🤬</code> label, if it exists in the repo.</span>
      </li>
      <li class="flex gap-3">
        <Icon name="ph:check-circle-duotone" class="mt-0.5 h-5 w-5 shrink-0 text-brand-600 dark:text-brand-400" />
        <span>Posts a detailed job summary table for traceability.</span>
      </li>
    </ul>
  </section>
</BaseLayout>
