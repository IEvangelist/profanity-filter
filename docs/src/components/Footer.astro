---
const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
---

<footer class="mt-32 border-t border-ink-200/60 dark:border-white/5 bg-ink-50 dark:bg-transparent">
  <div class="max-w-7xl mx-auto px-6 lg:px-8 py-12">
    <div class="grid gap-10 md:grid-cols-3 md:gap-8">
      <div>
        <div class="flex items-center gap-2.5">
          <span class="text-xl">🤬</span>
          <span class="font-semibold text-ink-900 dark:text-ink-50">Potty Mouth</span>
        </div>
        <p class="mt-3 text-sm text-ink-600 dark:text-ink-400 max-w-xs">
          A GitHub Action that keeps your issues, PRs, and comments professional &mdash; powered by .NET Native AOT.
        </p>
      </div>

      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider text-ink-500 dark:text-ink-400">Documentation</h3>
        <ul class="mt-4 space-y-2 text-sm">
          <li><a href={`${base}/getting-started`} class="text-ink-700 dark:text-ink-300 hover:text-brand-600 dark:hover:text-brand-400">Get started</a></li>
          <li><a href={`${base}/api`} class="text-ink-700 dark:text-ink-300 hover:text-brand-600 dark:hover:text-brand-400">API reference</a></li>
          <li><a href={`${base}/examples`} class="text-ink-700 dark:text-ink-300 hover:text-brand-600 dark:hover:text-brand-400">Examples</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider text-ink-500 dark:text-ink-400">Project</h3>
        <ul class="mt-4 space-y-2 text-sm">
          <li><a href="https://github.com/IEvangelist/profanity-filter" target="_blank" rel="noopener noreferrer" class="text-ink-700 dark:text-ink-300 hover:text-brand-600 dark:hover:text-brand-400">Source on GitHub</a></li>
          <li><a href="https://github.com/marketplace/actions/potty-mouth" target="_blank" rel="noopener noreferrer" class="text-ink-700 dark:text-ink-300 hover:text-brand-600 dark:hover:text-brand-400">Marketplace listing</a></li>
          <li><a href="https://github.com/IEvangelist/profanity-filter/issues" target="_blank" rel="noopener noreferrer" class="text-ink-700 dark:text-ink-300 hover:text-brand-600 dark:hover:text-brand-400">Report an issue</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-ink-200/60 dark:border-white/5 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-ink-500 dark:text-ink-400">
      <p>
        Built by
        <a href="https://github.com/IEvangelist" target="_blank" rel="noopener noreferrer" class="font-medium text-ink-700 dark:text-ink-200 hover:text-brand-600 dark:hover:text-brand-400">David Pine</a>
        &middot; MIT licensed &middot; &copy; {year}
      </p>
      <p>Made with ❤️ and a bit of 🤬</p>
    </div>
  </div>
</footer>
