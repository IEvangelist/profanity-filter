---
import { Icon } from 'astro-icon/components';

const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
---

<footer class="mt-32 border-t border-ink-200/60 dark:border-white/5 bg-ink-50 dark:bg-transparent relative overflow-hidden">
  <div class="bg-grid absolute inset-0 opacity-30 pointer-events-none"></div>
  <div class="relative max-w-7xl mx-auto px-6 lg:px-8 py-12">
    <div class="grid gap-10 md:grid-cols-3 md:gap-8">
      <div>
        <div class="flex items-center gap-2.5">
          <span class="text-xl">🤬</span>
          <span class="font-semibold text-ink-900 dark:text-ink-50">Potty Mouth</span>
        </div>
        <p class="mt-3 text-sm text-ink-600 dark:text-ink-400 max-w-xs">
          A GitHub Action that keeps your issues, PRs, and comments professional &mdash; powered by .NET Native AOT.
        </p>
      </div>

      <div>
        <h3 class="flex items-center gap-1.5 text-xs font-semibold uppercase tracking-wider text-ink-500 dark:text-ink-400">
          <Icon name="ph:book-open-duotone" class="h-3.5 w-3.5" />
          Documentation
        </h3>
        <ul class="mt-4 space-y-2 text-sm">
          <li>
            <a href={`${base}/getting-started`} class="inline-flex items-center gap-1.5 text-ink-700 dark:text-ink-300 hover:text-brand-600 dark:hover:text-brand-400">
              <Icon name="ph:rocket-launch-duotone" class="h-3.5 w-3.5" />
              Get started
            </a>
          </li>
          <li>
            <a href={`${base}/api`} class="inline-flex items-center gap-1.5 text-ink-700 dark:text-ink-300 hover:text-brand-600 dark:hover:text-brand-400">
              <Icon name="ph:book-bookmark-duotone" class="h-3.5 w-3.5" />
              Action reference
            </a>
          </li>
          <li>
            <a href={`${base}/aspire`} class="inline-flex items-center gap-1.5 text-ink-700 dark:text-ink-300 hover:text-brand-600 dark:hover:text-brand-400">
              <Icon name="ph:cube-duotone" class="h-3.5 w-3.5" />
              Aspire integration
            </a>
          </li>
          <li>
            <a href={`${base}/containers`} class="inline-flex items-center gap-1.5 text-ink-700 dark:text-ink-300 hover:text-brand-600 dark:hover:text-brand-400">
              <Icon name="ph:shipping-container-duotone" class="h-3.5 w-3.5" />
              Container images
            </a>
          </li>
          <li>
            <a href={`${base}/examples`} class="inline-flex items-center gap-1.5 text-ink-700 dark:text-ink-300 hover:text-brand-600 dark:hover:text-brand-400">
              <Icon name="ph:list-checks-duotone" class="h-3.5 w-3.5" />
              Examples
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h3 class="flex items-center gap-1.5 text-xs font-semibold uppercase tracking-wider text-ink-500 dark:text-ink-400">
          <Icon name="ph:git-branch-duotone" class="h-3.5 w-3.5" />
          Project
        </h3>
        <ul class="mt-4 space-y-2 text-sm">
          <li>
            <a href="https://github.com/IEvangelist/profanity-filter" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-ink-700 dark:text-ink-300 hover:text-brand-600 dark:hover:text-brand-400">
              <Icon name="simple-icons:github" class="h-3.5 w-3.5" />
              Source on GitHub
              <Icon name="ph:arrow-up-right-duotone" class="h-3 w-3 opacity-60" />
            </a>
          </li>
          <li>
            <a href="https://github.com/marketplace/actions/potty-mouth" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-ink-700 dark:text-ink-300 hover:text-brand-600 dark:hover:text-brand-400">
              <Icon name="ph:storefront-duotone" class="h-3.5 w-3.5" />
              Marketplace listing
              <Icon name="ph:arrow-up-right-duotone" class="h-3 w-3 opacity-60" />
            </a>
          </li>
          <li>
            <a href="https://www.nuget.org/packages/ProfanityFilter.Hosting" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-ink-700 dark:text-ink-300 hover:text-brand-600 dark:hover:text-brand-400">
              <Icon name="simple-icons:nuget" class="h-3.5 w-3.5" />
              ProfanityFilter.Hosting on NuGet
              <Icon name="ph:arrow-up-right-duotone" class="h-3 w-3 opacity-60" />
            </a>
          </li>
          <li>
            <a href="https://github.com/IEvangelist/profanity-filter/issues" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-ink-700 dark:text-ink-300 hover:text-brand-600 dark:hover:text-brand-400">
              <Icon name="ph:bug-duotone" class="h-3.5 w-3.5" />
              Report an issue
              <Icon name="ph:arrow-up-right-duotone" class="h-3 w-3 opacity-60" />
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-ink-200/60 dark:border-white/5 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-ink-500 dark:text-ink-400">
      <p>
        Built by
        <a href="https://github.com/IEvangelist" target="_blank" rel="noopener noreferrer" class="font-medium text-ink-700 dark:text-ink-200 hover:text-brand-600 dark:hover:text-brand-400">David Pine</a>
        &middot; MIT licensed &middot; &copy; {year}
      </p>
      <p class="inline-flex items-center gap-1.5">
        Made with
        <Icon name="ph:heart-duotone" class="h-3.5 w-3.5 text-rose-500" />
        and a bit of 🤬
      </p>
    </div>
  </div>
</footer>
