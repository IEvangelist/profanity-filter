---
import { Code } from 'astro:components';

interface Props {
  code: string;
  lang?: string;
  filename?: string;
}

const { code, lang = 'yaml', filename } = Astro.props;
---

<figure class="not-prose group relative my-6 overflow-hidden rounded-xl border border-ink-200 dark:border-white/10 bg-[#0d1117] shadow-lg shadow-ink-900/10 dark:shadow-black/40">
  {filename && (
    <figcaption class="flex items-center justify-between gap-3 border-b border-white/[0.06] bg-[#161b22] px-4 py-2.5 text-xs font-mono text-ink-400">
      <span class="flex items-center gap-2 min-w-0">
        <span class="inline-flex h-2 w-2 rounded-full bg-brand-500 shrink-0"></span>
        <span class="truncate">{filename}</span>
      </span>
      <span class="uppercase tracking-wider text-[10px] font-semibold text-ink-500 shrink-0">{lang}</span>
    </figcaption>
  )}
  <div class="relative">
    <Code code={code} lang={lang as any} theme="github-dark-default" />
    <button
      type="button"
      data-copy={code}
      class="copy-btn absolute top-3 right-3 inline-flex h-8 items-center gap-1.5 rounded-md border border-white/10 bg-ink-900/80 hover:bg-ink-900 px-2.5 text-xs text-ink-200 opacity-70 group-hover:opacity-100 focus-visible:opacity-100 transition-opacity backdrop-blur"
      aria-label="Copy code"
    >
      <svg class="copy-idle h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
      </svg>
      <svg class="copy-done hidden h-3.5 w-3.5 text-emerald-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="20 6 9 17 4 12"></polyline>
      </svg>
      <span class="copy-label">Copy</span>
    </button>
  </div>
</figure>
